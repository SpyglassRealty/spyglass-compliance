# Database
DATABASE_URL=postgresql://username:password@localhost:5432/spyglass_compliance

# Session
SESSION_SECRET=changeme-use-long-random-string-in-production

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# App Configuration
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=86400000

# PDF Generation
CDA_OUTPUT_DIR=./uploads/cdas

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100